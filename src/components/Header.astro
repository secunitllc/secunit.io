---
import ThemeToggle from "@/components/ThemeToggle.astro";
import navConfig from "@/config/en/navData.json.ts";
---
<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-wordmark" aria-label="Secunit Mercantile home">
      <span>Secunit</span> Mercantile
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      {navConfig.map((item) => (
        <a href={item.link} class="site-nav__link hidden md:inline-block">{item.text}</a>
      ))}
      <a href="/contact" class="site-nav__cta">
        Let's Talk
      </a>
      <ThemeToggle />
      <button
        id="mobile-nav-toggle"
        class="mobile-nav-toggle md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg id="mobile-nav-open-icon" class="h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg id="mobile-nav-close-icon" class="hidden h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>
  </div>
  <nav id="mobile-nav" class="mobile-nav md:hidden" aria-label="Mobile navigation" hidden>
    {navConfig.map((item) => (
      <a href={item.link} class="mobile-nav__link">{item.text}</a>
    ))}
    <a href="/contact" class="mobile-nav__link">Let's Talk</a>
  </nav>
</header>

<script>
  const toggle = document.getElementById("mobile-nav-toggle");
  const panel = document.getElementById("mobile-nav");
  const openIcon = document.getElementById("mobile-nav-open-icon");
  const closeIcon = document.getElementById("mobile-nav-close-icon");

  function setOpen(open: boolean) {
    if (!toggle || !panel) return;
    panel.hidden = !open;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    openIcon?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
  }

  toggle?.addEventListener("click", () => {
    setOpen(panel?.hidden === true);
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && panel?.hidden === false) {
      setOpen(false);
      toggle?.focus();
    }
  });
</script>
