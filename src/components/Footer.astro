---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p class="site-footer__statement">
    Enterprise guidance for growing businesses.
  </p>

  <div class="site-footer__directory">
    <section class="site-footer__brand" aria-labelledby="footer-brand">
      <a href="/" class="site-wordmark" id="footer-brand" aria-label="secunit, llc home">
        <span>secunit</span>, llc
      </a>
      <p>
        Security, DevOps, SRE, and AI consulting from <a href="https://secunit.io" rel="noopener">secunit, llc</a>.
      </p>
      <ul class="site-footer__social" aria-label="External profiles">
        <li>
          <a
            href="https://linkedin.com/company/secunit-mercantile"
            rel="me noopener"
            aria-label="LinkedIn profile"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </li>
        <li>
          <a
            href="https://github.com/x86txt"
            rel="me noopener"
            aria-label="GitHub profile"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false" fill="currentColor">
              <path d="M12 .5C5.65.5.5 5.65.5 12.02c0 5.1 3.29 9.42 7.86 10.95.57.11.78-.25.78-.55v-1.94c-3.2.7-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.68-1.27-1.68-1.04-.71.08-.69.08-.69 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.68 1.25 3.34.95.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.59.23 2.76.12 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.07.78 2.16v3.2c0 .31.21.67.79.55C20.22 21.43 23.5 17.12 23.5 12.02 23.5 5.65 18.35.5 12 .5z" />
            </svg>
          </a>
        </li>
      </ul>
    </section>

    <section class="site-footer__col" aria-labelledby="footer-channels">
      <p id="footer-channels" class="site-footer__kicker">[ Secure channels ]</p>
      <ul>
        <li>
          <a href="mailto:hello@secunit.io">
            <img src="/proton/proton-mail.svg" alt="" width="18" height="18" loading="lazy" decoding="async" />
            <span>hello@secunit.io</span>
          </a>
        </li>
        <li>
          <a
            href="https://calendar.proton.me/bookings#56ol5O7F5ohweF0c3F_Ggfrg6NcUnUvWIMvfutfiZW4="
            rel="noopener"
          >
            <img src="/proton/proton-calendar.svg" alt="" width="18" height="18" loading="lazy" decoding="async" />
            <span>Request a meeting</span>
          </a>
        </li>
        <li>
          <a
            href="https://drive.proton.me/urls/AEJE36XH8G#kD56WxZRdyjP"
            rel="noopener"
          >
            <img src="/proton/proton-drive.svg" alt="" width="18" height="18" loading="lazy" decoding="async" />
            <span>Secure file exchange</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="site-footer__col" aria-labelledby="footer-tools">
      <p id="footer-tools" class="site-footer__kicker">[ Tools ]</p>
      <ul>
        <li>
          <a href="https://srex.secunit.io" rel="noopener">
            <span class="site-footer__tag">SRE</span>
            <span>Reliability Audit</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="site-footer__col" aria-labelledby="footer-security">
      <p id="footer-security" class="site-footer__kicker">[ Security ]</p>
      <ul>
        <li>
          <a href="https://secunit.io/security/ecc.txt" rel="noopener">
            <span class="site-footer__tag">GPG</span>
            <span>ECC public key</span>
          </a>
        </li>
        <li>
          <a href="https://secunit.io/security/rsa.txt" rel="noopener">
            <span class="site-footer__tag">GPG</span>
            <span>RSA public key</span>
          </a>
        </li>
        <li>
          <a href="/.well-known/security.txt">
            <span class="site-footer__tag">TXT</span>
            <span>security.txt</span>
          </a>
        </li>
        <li>
          <a href="https://github.com/x86txt" rel="me noopener">
            <span class="site-footer__tag">GH</span>
            <span>x86txt</span>
          </a>
        </li>
      </ul>
    </section>
  </div>

  <div class="site-footer__meta">
    <p>&copy; {year} secunit, llc &middot; secunit.io</p>
    <nav aria-label="Footer navigation">
      <a href="/services">Services</a>
      <a href="/technologies">Technologies</a>
      <a href="/about">About</a>
      <a href="/contact">Let's Talk</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/security">Security</a>
    </nav>
  </div>
</footer>
