---
import Base from "@/layouts/Base.astro";

const services = [
  {
    title: "AI Enablement",
    tag: "Workflow automation",
    body: "Cut through the AI hype. We help you identify practical AI tools and workflows that actually accelerate your business — without the confusion or wasted spend.",
  },
  {
    title: "FinOps & Cost Optimization",
    tag: "Cloud efficiency",
    body: "Evaluate existing deployments for cost savings opportunities. Reduce cloud spend without sacrificing performance or reliability.",
  },
  {
    title: "Virtual DevOps & SRE",
    tag: "Engineering leadership",
    body: "Fractional engineering leadership for CI/CD pipelines, infrastructure as code, observability, and reliability programs. Get senior expertise without a full-time hire.",
  },
  {
    title: "Virtual CISO & InfoSec",
    tag: "Security posture",
    body: "Security leadership on your terms. Compliance programs, threat modeling, vulnerability management, and executive-ready reporting.",
  },
];

const steps = [
  {
    num: "01",
    title: "Real Experience",
    body: "Our team has led cloud migrations, built SOC2-aligned security programs, and helped organizations adopt DevOps and SRE practices.",
  },
  {
    num: "02",
    title: "Real Results",
    body: "We've reduced outages, cut costs, and accelerated delivery for organizations of all sizes.",
  },
  {
    num: "03",
    title: "Real Accessibility",
    body: "We started Secunit Mercantile to make that expertise accessible to growing businesses — on flexible retainers that make sense for your budget.",
  },
];

const clients = [
  "The Hartford",
  "IBM",
  "Wells Fargo",
  "AIG",
  "Cyware",
  "AlphaTheory",
  "Honda Aircraft",
];
---

<Base title="Security, DevOps & AI Consulting">
  <section class="bento-hero" aria-labelledby="home-title">
    <div class="bento-tile bento-tile--hero">
      <p class="home-kicker">Security, DevOps & AI Consulting</p>
      <h1 id="home-title">Enterprise-Grade Expertise. Small Business Pricing.</h1>
      <p class="bento-tile__lede">
        Security, DevOps, and AI consulting from senior engineers who've operated at scale — now available to growing businesses like yours.
      </p>
      <div class="home-actions" aria-label="Primary actions">
        <a class="home-button home-button--primary" href="/contact">Let's Talk</a>
        <a class="home-button home-button--secondary" href="/services">View Services</a>
      </div>
    </div>

    <div class="bento-stats" role="group" aria-label="Track record">
      <div class="bento-tile bento-tile--stat">
        <span class="bento-stat__label">Years Experience</span>
        <strong class="bento-stat__value">20+</strong>
      </div>
      <div class="bento-tile bento-tile--stat bento-tile--accent">
        <span class="bento-stat__label">Certified</span>
        <strong class="bento-stat__value">CISSP</strong>
      </div>
      <div class="bento-tile bento-tile--stat bento-tile--accent">
        <span class="bento-stat__label">K8s Migrations</span>
        <strong class="bento-stat__value">280+</strong>
      </div>
      <div class="bento-tile bento-tile--stat">
        <span class="bento-stat__label">Uptime Achieved</span>
        <strong class="bento-stat__value">99.99%</strong>
      </div>
    </div>
  </section>

  <section class="bento-section" aria-labelledby="services-title">
    <header class="bento-section__head">
      <p class="home-kicker">What We Do</p>
      <h2 id="services-title">Services that scale with you</h2>
      <p>Practical expertise that makes a real difference for your business.</p>
    </header>
    <div class="bento-grid bento-grid--services">
      {services.map((service) => (
        <article class="bento-tile bento-tile--service">
          <span class="bento-tile__tag">{service.tag}</span>
          <h3>{service.title}</h3>
          <p>{service.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="bento-section" aria-labelledby="workflow-title">
    <header class="bento-section__head">
      <p class="home-kicker">Why Secunit</p>
      <h2 id="workflow-title">You Shouldn't Need Enterprise Budgets</h2>
      <p>
        Most small businesses don't need more tools or junior consultants — they need experienced guidance from people who've actually built and operated production systems at scale.
      </p>
    </header>
    <div class="bento-grid bento-grid--steps">
      {steps.map((step) => (
        <article class="bento-tile bento-tile--step">
          <span class="bento-step__num" aria-hidden="true">{step.num}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="bento-section" aria-labelledby="clients-title">
    <header class="bento-section__head">
      <p class="home-kicker">Trusted By</p>
      <h2 id="clients-title">Companies we've worked with</h2>
      <p>
        Here are some of the companies we have worked with — let us bring that expertise to your small or mid-sized business.
      </p>
    </header>
    <ul class="bento-grid bento-grid--clients">
      {clients.map((name) => (
        <li class="bento-chip">{name}</li>
      ))}
    </ul>
  </section>

  <section class="bento-tile bento-tile--cta" aria-labelledby="cta-title">
    <div>
      <p class="home-kicker">Ready to get started?</p>
      <h2 id="cta-title">Tell us about your challenges.</h2>
      <p>We'll show you how senior-level expertise can help — without the enterprise price tag.</p>
    </div>
    <div class="home-actions">
      <a class="home-button home-button--primary home-button--on-accent" href="/contact">Let's Talk</a>
    </div>
  </section>
</Base>
