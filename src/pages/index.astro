---
import Base from "@/layouts/Base.astro";
---

<Base title="Security, DevOps & AI Consulting">
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero__copy">
      <p class="home-kicker">Security, DevOps & AI Consulting</p>
      <h1 id="home-title">Enterprise-Grade Expertise. Small Business Pricing.</h1>
      <p>
        Security, DevOps, and AI consulting from senior engineers who've operated at scale — now available to growing businesses like yours.
      </p>
      <div class="home-actions" aria-label="Primary actions">
        <a class="home-button home-button--primary" href="/contact">Let's Talk</a>
        <a class="home-button home-button--secondary" href="/services">View Services</a>
      </div>
    </div>

    <figure class="reliability-map" aria-labelledby="map-title">
      <figcaption id="map-title">
        <span>Proven Track Record</span>
      </figcaption>
      <div class="reliability-map__canvas" role="img" aria-label="Stats grid showing years experience, certifications, migrations, and uptime">
        <div class="map-node map-node--stat map-node--stat-tl">
          <span>Years Experience</span>
          <strong class="map-node__value">20+</strong>
        </div>
        <div class="map-node map-node--stat map-node--stat-tr map-node--highlight">
          <span>Certified</span>
          <strong class="map-node__value">CISSP</strong>
        </div>
        <div class="map-node map-node--stat map-node--stat-bl map-node--highlight">
          <span>K8s Migrations</span>
          <strong class="map-node__value">280+</strong>
        </div>
        <div class="map-node map-node--stat map-node--stat-br">
          <span>Uptime Achieved</span>
          <strong class="map-node__value">99.99%</strong>
        </div>
        <svg class="map-lines" viewBox="0 0 640 430" aria-hidden="true" focusable="false">
          <path d="M128 107 L 512 107" stroke-dasharray="4 4" />
          <path d="M128 322 L 512 322" stroke-dasharray="4 4" />
          <path d="M128 107 L 128 322" stroke-dasharray="4 4" />
          <path d="M512 107 L 512 322" stroke-dasharray="4 4" />
          <path d="M128 107 L 512 322" stroke-dasharray="4 4" />
        </svg>
      </div>
    </figure>
  </section>

  <section class="home-section home-section--spec" aria-labelledby="services-title">
    <div class="home-section__intro">
      <h2 id="services-title">What We Do</h2>
      <p>
        Practical expertise that makes a real difference for your business.
      </p>
    </div>
    <div class="spec-sheet" role="list">
      <article class="spec-row" role="listitem">
        <h3>AI Enablement</h3>
        <p>Cut through the AI hype. We help you identify practical AI tools and workflows that actually accelerate your business — without the confusion or wasted spend.</p>
        <span>Workflow automation</span>
      </article>
      <article class="spec-row" role="listitem">
        <h3>FinOps & Cost Optimization</h3>
        <p>Evaluate existing deployments for cost savings opportunities. Reduce cloud spend without sacrificing performance or reliability.</p>
        <span>Cloud efficiency</span>
      </article>
      <article class="spec-row" role="listitem">
        <h3>Virtual DevOps & SRE</h3>
        <p>Fractional engineering leadership for CI/CD pipelines, infrastructure as code, observability, and reliability programs. Get senior expertise without a full-time hire.</p>
        <span>Engineering leadership</span>
      </article>
      <article class="spec-row" role="listitem">
        <h3>Virtual CISO & InfoSec</h3>
        <p>Security leadership on your terms. Compliance programs, threat modeling, vulnerability management, and executive-ready reporting.</p>
        <span>Security posture</span>
      </article>
    </div>
  </section>

  <section class="home-section home-section--workflow" aria-labelledby="workflow-title">
    <div class="home-section__intro">
      <h2 id="workflow-title">You Shouldn't Need Enterprise Budgets</h2>
      <p>
        Most small businesses don't need more tools or junior consultants — they need experienced guidance from people who've actually built and operated production systems at scale.
      </p>
    </div>
    <ol class="workflow-list">
      <li>
        <span>1.0</span>
        <h3>Real Experience</h3>
        <p>Our team has led cloud migrations, built SOC2-aligned security programs, and helped organizations adopt DevOps and SRE practices.</p>
      </li>
      <li>
        <span>2.0</span>
        <h3>Real Results</h3>
        <p>We've reduced outages, cut costs, and accelerated delivery for organizations of all sizes.</p>
      </li>
      <li>
        <span>3.0</span>
        <h3>Real Accessibility</h3>
        <p>We started Secunit Mercantile to make that expertise accessible to growing businesses — on flexible retainers that make sense for your budget.</p>
      </li>
    </ol>
  </section>

  <section class="tech-hero" aria-labelledby="clients-title">
    <div class="tech-hero__copy">
      <p class="home-kicker">Trusted By</p>
      <h2 id="clients-title">Companies we've worked with</h2>
      <p>
        Here are some of the companies we have worked with — let us bring that expertise to your small or mid-sized business.
      </p>
    </div>
  </section>

  <section class="tech-catalog" aria-label="Client logos">
    <div class="tech-group">
      <div class="tech-group__head">
        <p class="tech-group__kicker">Enterprises</p>
        <h2>Financial & Tech</h2>
      </div>
      <ul class="tech-grid">
        <li class="tech-chip">
          <span>The Hartford</span>
        </li>
        <li class="tech-chip">
          <span>IBM</span>
        </li>
        <li class="tech-chip">
          <span>Wells Fargo</span>
        </li>
        <li class="tech-chip">
          <span>AIG</span>
        </li>
        <li class="tech-chip">
          <span>Cyware</span>
        </li>
        <li class="tech-chip">
          <span>AlphaTheory</span>
        </li>
        <li class="tech-chip">
          <span>Honda Aircraft</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="home-cta" aria-labelledby="cta-title">
    <div>
      <p class="home-kicker">Ready to get started?</p>
      <h2 id="cta-title">Tell us about your challenges.</h2>
      <p>We'll show you how senior-level expertise can help — without the enterprise price tag.</p>
    </div>
    <div class="home-actions">
      <a class="home-button home-button--primary" href="/contact">Let's Talk</a>
    </div>
  </section>
</Base>
