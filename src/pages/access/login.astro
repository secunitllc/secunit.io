---
import AccessLayout from "@/layouts/AccessLayout.astro";

// --- Configure this list for your Zero Trust team -------------------------
// For each identity provider you want a branded button for, open Zero Trust
// dashboard -> Settings -> Authentication, open the provider, and copy its
// exact sign-in link (Cloudflare shows a "Login URL" / "Test" link per
// provider). Paste that full URL below as `loginUrl` — this page appends
// `redirect_url` to it automatically, so do not hand-edit that part.
//
// `defaultLoginUrl` is the fallback used by "Continue with another method"
// (One-Time PIN, etc). It should be your team's bare Access login endpoint:
//   https://<your-team-name>.cloudflareaccess.com/cdn-cgi/access/login/<app-domain>
const identityProviders = [
  // { name: "Google Workspace", loginUrl: "https://<your-team-name>.cloudflareaccess.com/cdn-cgi/access/login/<app-domain>?kid=<idp-id>" },
  // { name: "GitHub", loginUrl: "https://<your-team-name>.cloudflareaccess.com/cdn-cgi/access/login/<app-domain>?kid=<idp-id>" },
];
const defaultLoginUrl =
  "https://<your-team-name>.cloudflareaccess.com/cdn-cgi/access/login/<app-domain>";
// ---------------------------------------------------------------------------
---

<AccessLayout
  title="Sign in"
  description="Sign in to access Secunit's internal tools."
  kicker="Zero Trust"
>
  <h1 class="access-h1">Sign in to continue</h1>
  <p class="access-lead">Choose an identity provider to access this application.</p>

  <div id="idp-list" class="access-idp-list" data-default-login-url={defaultLoginUrl}>
    {
      identityProviders.map((idp) => (
        <a
          href={idp.loginUrl}
          class="access-idp-button"
          data-idp-button
          data-base-url={idp.loginUrl}
        >
          <svg
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <rect x="3" y="11" width="18" height="10" rx="2" />
            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
          <span>Continue with {idp.name}</span>
        </a>
      ))
    }
    <a
      href={defaultLoginUrl}
      id="default-login-link"
      class="access-idp-button access-idp-button--secondary"
      data-base-url={defaultLoginUrl}
    >
      <span>Continue with One-Time PIN</span>
    </a>
  </div>

  <p class="access-lead access-lead--small">
    Not authorized? Contact your administrator at <a href="mailto:security@secunit.io"
      >security@secunit.io</a
    >.
  </p>
</AccessLayout>

<script>
  // Preserve Cloudflare Access's `redirect_url` (and any other query params
  // it sends) across every login link on this page, so the user lands back
  // on the application they originally requested after signing in.
  const incoming = new URLSearchParams(window.location.search);
  const redirectUrl = incoming.get("redirect_url");

  document.querySelectorAll<HTMLAnchorElement>("[data-base-url]").forEach((link) => {
    const base = link.dataset.baseUrl;
    if (!base || !redirectUrl) return;
    try {
      const url = new URL(base);
      url.searchParams.set("redirect_url", redirectUrl);
      link.href = url.toString();
    } catch {
      // base URL is still a placeholder (e.g. <your-team-name>) — leave as-is
    }
  });
</script>

<style>
  .access-h1 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 750;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .access-lead {
    margin: 0;
    color: var(--color-ink-2);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .access-lead--small {
    margin-block-start: var(--space-xs);
    color: var(--color-muted);
    font-size: var(--text-xs);
  }

  .access-lead a,
  .access-lead--small a {
    color: var(--color-accent-text);
    text-decoration: none;
    border-bottom: var(--rule-hair) solid color-mix(in oklch, var(--color-accent) 40%, transparent);
  }

  .access-lead a:hover,
  .access-lead--small a:hover {
    border-color: var(--color-accent);
  }

  .access-idp-list {
    display: grid;
    gap: var(--space-sm);
    margin-block-start: var(--space-xs);
  }

  .access-idp-button {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    border: var(--rule-hair) solid var(--color-ink);
    border-radius: var(--radius-pill);
    background: var(--color-ink);
    color: var(--color-paper);
    font-size: var(--text-sm);
    font-weight: 650;
    line-height: 1;
    text-decoration: none;
    transition:
      background-color var(--dur-short) var(--ease-out),
      border-color var(--dur-short) var(--ease-out),
      transform 100ms var(--ease-out);
  }

  .access-idp-button:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-ink);
    transform: translateY(-1px);
  }

  .access-idp-button:active {
    transform: translateY(1px);
  }

  .access-idp-button--secondary {
    background: transparent;
    border-color: var(--color-rule);
    color: var(--color-ink);
  }

  .access-idp-button--secondary:hover {
    border-color: var(--color-accent);
    background: transparent;
    color: var(--color-accent-text);
  }
</style>
