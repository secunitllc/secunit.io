---
import Base from "@/layouts/Base.astro";

// Local app icons in public/logos/ai/
const aiTools = [
 { name: "ChatGPT", logo: "chatgpt" },
 { name: "Claude", logo: "claude" },
 { name: "OpenClaw", logo: "openclaw" },
 { name: "Copilot", logo: "copilot" },
 { name: "Gemini", logo: "gemini" },
 { name: "Grok", logo: "grok" },
 { name: "xAI", logo: "xai" },
 { name: "Ollama", logo: "ollama" },
 { name: "DeepSeek", logo: "deepseek" },
 { name: "Cursor", logo: "cursor" },
 { name: "Perplexity", logo: "perplexity" },
 { name: "Open WebUI", logo: "open-webui" },
 { name: "Apple Intelligence", logo: "apple-intelligence" },
 { name: "Meta AI", logo: "meta-ai" },
];
---

<Base 
 title="Services" 
 description="AI Enablement, FinOps, Virtual DevOps & SRE, and Virtual CISO services for small and mid-sized businesses."
>
 <section class="page-header" aria-labelledby="services-title">
  <div class="page-header__copy">
   <p class="home-kicker">Expertise On Demand</p>
   <h1 id="services-title">Services Built for Growing Businesses</h1>
   <p>
    Flexible engagement models. Senior expertise. No bloated retainers.
   </p>
   <div class="page-header__stats">
    <span class="page-header__stat">4 Core Services</span>
    <span class="page-header__stat">Flexible Retainers</span>
    <span class="page-header__stat">Senior-Level Only</span>
   </div>
   <div class="nav-pills">
    <a href="#devops-sre" class="nav-pill">DevOps & SRE</a>
    <a href="#ai-enablement" class="nav-pill">AI Enablement</a>
    <a href="#finops" class="nav-pill">FinOps</a>
    <a href="#virtual-ciso" class="nav-pill">Virtual CISO</a>
   </div>
  </div>
 </section>

 <!-- DevOps & SRE -->
 <section id="devops-sre" class="service-detail">
  <div class="service-detail__intro">
   <p class="service-detail__tagline">Reliable systems. Faster delivery. Less noise.</p>
   <h2>Virtual DevOps & Site Reliability Engineering</h2>
   <p>
    You need modern infrastructure practices, but a full-time DevOps or SRE hire might be overkill — or impossible to find.
   </p>
   <p>
    Our virtual engineering services give you access to senior talent who've migrated hundreds of services to Kubernetes, reduced monthly alerts from 1,000+ to under 50, and built disaster recovery programs that actually work when you need them.
   </p>
  </div>
  <div class="service-detail__aside">
   <div class="callout">
    <svg class="callout__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
    </svg>
    <div>
     <h3>SRE Reliability Audit</h3>
     <p>
      Not ready for a full engagement? Start with our self-serve reliability audit toolkit at
      <a href="https://srex.secunit.io" rel="noopener" class="callout__link">srex.secunit.io</a>
      — assess your architecture, telemetry, and recovery posture, then bring us the results.
     </p>
    </div>
   </div>
   <ul class="checklist">
    <li>Design and implement CI/CD pipelines (GitHub Actions, Jenkins, ArgoCD)</li>
    <li>Build infrastructure as code with Terraform, AWS CDK, or Helm</li>
    <li>Architect Kubernetes deployments and container strategies</li>
    <li>Implement observability (Prometheus, Grafana, Datadog)</li>
    <li>Establish SLIs, SLOs, and incident response processes</li>
    <li>Reduce alert fatigue and conduct blameless post-mortems</li>
   </ul>
  </div>
 </section>

 <!-- AI Enablement -->
 <section id="ai-enablement" class="service-detail">
  <div class="service-detail__intro">
   <p class="service-detail__tagline">Make sense of AI. Put it to work.</p>
   <h2>AI Enablement</h2>
   <p>
    AI is everywhere — but most businesses are stuck between "we should do something with AI" and "we have no idea where to start."
   </p>
   <p>
    We cut through the noise and help you identify high-impact use cases, evaluate tools without vendor bias, and implement workflows that actually integrate with your existing systems.
   </p>
  </div>
  <div class="service-detail__aside">
   <div class="callout">
    <svg class="callout__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
    </svg>
    <div>
     <h3>Too Many Tools?</h3>
     <p>
      ChatGPT, Claude Code, OpenClaw, Copilot — we can help you make sense of all of these and pick the ones that actually fit your business.
     </p>
     <div class="callout-marquee" aria-hidden="true">
      <div class="callout-marquee__track">
       {[...aiTools, ...aiTools].map((tool) => (
        <span class="callout-marquee__item">
         <img
          src={`/logos/ai/${tool.logo}.png`}
          alt=""
          title={tool.name}
          width="44"
          height="44"
          loading="lazy"
          decoding="async"
         />
        </span>
       ))}
      </div>
     </div>
    </div>
   </div>
   <ul class="checklist">
    <li>Identify high-impact AI use cases specific to your business</li>
    <li>Evaluate tools and platforms without vendor bias</li>
    <li>Implement AI workflows that integrate with your existing systems</li>
    <li>Train your team to use AI tools effectively and safely</li>
    <li>Establish governance and policies for responsible AI use</li>
   </ul>
  </div>
 </section>

 <!-- FinOps -->
 <section id="finops" class="service-detail">
  <div class="service-detail__intro">
   <p class="service-detail__tagline">Reduce cloud spend without sacrificing performance.</p>
   <h2>FinOps & Cloud Cost Optimization</h2>
   <p>
    Cloud costs can spiral out of control — especially when you're scaling fast. But cutting costs blindly can break things or slow you down.
   </p>
   <p>
    Our FinOps services evaluate your existing deployments to identify real cost savings opportunities. We analyze your infrastructure, usage patterns, and billing data to find waste, optimize resource sizing, and recommend changes that reduce spend while maintaining or improving performance.
   </p>
  </div>
  <div class="service-detail__aside">
   <div class="callout">
    <svg class="callout__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
    </svg>
    <div>
     <h3>Our Guarantee</h3>
     <p>
      If we don't save you more than our billable hours, you don't pay. We're confident in our ability to find real cost savings in your cloud infrastructure.
     </p>
    </div>
   </div>
   <ul class="checklist">
    <li>Comprehensive cloud cost audits and spend analysis</li>
    <li>Identify and eliminate unused or underutilized resources</li>
    <li>Right-size compute, storage, and database resources</li>
    <li>Optimize reserved instances, savings plans, and spot instances</li>
    <li>Implement cost allocation and chargeback strategies</li>
    <li>Establish FinOps practices and cost monitoring dashboards</li>
   </ul>
  </div>
 </section>

 <!-- Virtual CISO -->
 <section id="virtual-ciso" class="service-detail">
  <div class="service-detail__intro">
   <p class="service-detail__tagline">Security leadership without the full-time cost.</p>
   <h2>Virtual CISO & Information Security</h2>
   <p>
    Growing businesses face real security risks — but rarely have the budget for a dedicated CISO. Our virtual CISO services give you experienced security leadership on a flexible retainer.
   </p>
   <p>
    Our founder holds an active CISSP (since 2017) and has served in acting CISO roles, working directly with executives while remaining hands-on with technical implementation.
   </p>
  </div>
  <div class="service-detail__aside">
   <div class="callout">
    <svg class="callout__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
    </svg>
    <div>
     <h3>Credentialed Leadership</h3>
     <p>
      Every security engagement is led by an active CISSP with acting-CISO experience in SOC2, FINRA, SEC, and SOX environments — executive-ready reporting included.
     </p>
    </div>
   </div>
   <ul class="checklist">
    <li>Develop and maintain security policies and programs</li>
    <li>Achieve and maintain compliance (SOC2, FINRA, SEC, SOX)</li>
    <li>Conduct risk assessments and threat modeling</li>
    <li>Manage vulnerability programs and penetration testing</li>
    <li>Implement Zero Trust architectures and cloud security</li>
    <li>Respond to security incidents and prepare for audits</li>
   </ul>
  </div>
 </section>

 <!-- Engagement Models -->
 <section class="engagement-section" aria-labelledby="engagement-title">
  <div class="engagement-section__intro">
   <h2 id="engagement-title">Flexible Engagement Models</h2>
   <p>
    From hourly consulting to fixed-price projects — we offer options that fit your budget and avoid surprises.
   </p>
  </div>
  <div class="engagement-grid">
   <div class="engagement-card">
    <h3>Hourly</h3>
    <p>Pay only for what you need. Ideal for ad-hoc consulting, reviews, or quick wins.</p>
   </div>
   <div class="engagement-card">
    <h3>Discovery</h3>
    <p>2–4 week assessment of your environment and opportunities. Deliverable: prioritized roadmap.</p>
   </div>
   <div class="engagement-card">
    <h3>Fixed Price</h3>
    <p>No surprises. Defined scope, defined cost. Perfect for migrations, implementations, or audits.</p>
   </div>
   <div class="engagement-card">
    <h3>Retainer</h3>
    <p>Monthly hours for ongoing advisory, implementation, and support. Scale as needs change.</p>
   </div>
   <div class="engagement-card">
    <h3>Project</h3>
    <p>Time & materials for larger initiatives like compliance prep or cloud migration.</p>
   </div>
  </div>
  <div class="home-actions engagement-section__actions">
   <a class="home-button home-button--primary" href="/contact">Let's Design Your Engagement</a>
  </div>
 </section>
</Base>
