---
import ContactFormCore from "@/components/contact/ContactFormCore.astro";
import Base from "@/layouts/Base.astro";
import ProtonLogo from "@/assets/images/brands/proton.svg";
import ProtonDriveLogo from "@/assets/images/brands/protondrive.svg";
---

<Base
  title="Contact"
  description="Get in touch with Secunit Mercantile. Tell us about your business challenges and we'll show you how we can help."
>
  <section class="contact-header" aria-labelledby="contact-title">
    <p class="home-kicker">Contact</p>
    <h1 id="contact-title">Let's Talk</h1>
    <p>
      Tell us a bit about your business and what you're looking to accomplish. We'll get back to you within one business day.
    </p>
  </section>

  <div class="contact-privacy">
    <div class="contact-privacy__box">
      <div class="contact-privacy__info">
        <ProtonLogo class="h-8 w-auto shrink-0" />
        <div>
          <h3>We care about privacy.</h3>
          <p>
            We use the Proton platform for secure communications and publish our keys so you can validate authenticity.
          </p>
        </div>
      </div>
      <div class="contact-privacy__links">
        <a href="/security/ecc.txt" class="contact-key-link">ECC public key</a>
        <a href="/security/rsa.txt" class="contact-key-link">RSA public key</a>
      </div>
    </div>
    <div class="contact-privacy__secure">
      <ProtonDriveLogo class="h-6 w-auto shrink-0" />
      <p>
        Need to send us a file securely? Drop it here:
        <a
          href="https://drive.proton.me/urls/AEJE36XH8G#kD56WxZRdyjP"
          target="_blank"
          rel="noopener noreferrer"
        >
          Proton Drive secure drop
        </a>
      </p>
    </div>
  </div>

  <div class="contact-form-wrap">
    <div class="contact-form-card">
      <ContactFormCore
        submitClass="contact-submit"
      />
    </div>
  </div>

  <section class="contact-info-row" aria-label="Contact information">
    <div class="contact-info-grid">
      <div class="contact-info-item">
        <h3>Prefer email?</h3>
        <a href="mailto:hello@secunit.io">hello@secunit.io</a>
      </div>
      <div class="contact-info-item">
        <h3>Location</h3>
        <p>Charlotte, NC</p>
        <p class="contact-info-sub">Remote-first — we work with clients nationwide</p>
      </div>
    </div>
  </section>
</Base>
